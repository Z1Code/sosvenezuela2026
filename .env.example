# ─────────────────────────────────────────────────────────────
# Variables de entorno — COPIA este archivo a `.env.local` y
# rellena con tus propios valores. NUNCA subas `.env.local` a git.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon u otro). Conexión pooled para la app, unpooled para migraciones.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Secreto para firmar los JWT de sesión. Usa una cadena larga y aleatoria.
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Email de la cuenta Google que tendrá acceso al panel /admin.
ADMIN_EMAIL=tu-email@gmail.com

# Google OAuth (consola de Google Cloud → Credenciales → ID de cliente OAuth).
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# URL base pública del sitio (sin barra final).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Tiles del mapa (Leaflet). Puede dejarse el valor por defecto de CARTO.
NEXT_PUBLIC_TILE_URL=https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png

# ─────────────────────────────────────────────────────────────
# Scripts de sincronización de datos (scripts/sync.cjs, scripts/newsweep.cjs).
# Solo necesarios si vas a correr la ingesta de datos de plataformas ciudadanas.
# VTB_KEY / TVE_KEY son claves anon/publishable PÚBLICAS de esas plataformas.
# ─────────────────────────────────────────────────────────────
VTB_KEY=
TVE_KEY=
# Modelo de Ollama para geolocalizar noticias (newsweep.cjs). Opcional.
OLLAMA_MODEL=llama3.1:8b
